# Python API — environment variables
# Copy this file to python.env and fill in your actual values.
# python.env is never committed to git.

# ── NASA API ─────────────────────────────────────────────────────────────────
# Get a free key at https://api.nasa.gov/
NASA_API_KEY=YOUR_NASA_API_KEY_HERE

# ── Rust Engine ───────────────────────────────────────────────────────────────
# Local dev:   http://localhost:8080
# Docker:      http://rust-engine:8080  (overridden automatically by compose)
RUST_ENGINE_URL=http://localhost:8080

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev:   mongodb://localhost:27017
# Docker:      mongodb://mongodb:27017  (overridden automatically by compose)
# Atlas:       mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
MONGO_DB=astroforge_db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIRECTORY=./storage/logs

# ── HTTP ─────────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=30

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to false in production
DEBUG=false
